{
  "datasets": [
    {
      "name": "edmonton_yelp",
      "displayName": "Edmonton Yelp Reviews",
      "config": {
        "source": "demo_catalog.demo_yelp_academic.ss_zz_gold_fact_review",
        "measures": [
          {
            "name": "total_reviews",
            "expr": "COUNT(1)",
            "displayName": "Total Reviews"
          },
          {
            "name": "avg_stars",
            "expr": "AVG(stars)",
            "displayName": "Avg Stars",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              }
            }
          },
          {
            "name": "total_useful_votes",
            "expr": "SUM(review_useful_votes)",
            "displayName": "Total Useful Votes"
          },
          {
            "name": "total_funny_votes",
            "expr": "SUM(review_funny_votes)",
            "displayName": "Total Funny Votes"
          },
          {
            "name": "total_cool_votes",
            "expr": "SUM(review_cool_votes)",
            "displayName": "Total Cool Votes"
          },
          {
            "name": "five_star_reviews",
            "expr": "COUNT(1) FILTER (WHERE stars = 5.0)",
            "displayName": "5-Star Reviews"
          },
          {
            "name": "one_star_reviews",
            "expr": "COUNT(1) FILTER (WHERE stars = 1.0)",
            "displayName": "1-Star Reviews"
          },
          {
            "name": "five_star_pct",
            "expr": "MEASURE(five_star_reviews) * 100.0 / MEASURE(total_reviews)",
            "displayName": "5-Star %",
            "format": {
              "type": "percentage",
              "decimalPlaces": {
                "type": "exact",
                "places": 1.0
              }
            }
          }
        ],
        "filter": "business.city = 'Edmonton'",
        "version": "1.1",
        "comment": "Edmonton Yelp business review metrics",
        "dimensions": [
          {
            "name": "review_date",
            "expr": "date_dim.date_actual",
            "displayName": "Review Date"
          },
          {
            "name": "year",
            "expr": "date_dim.year",
            "displayName": "Year"
          },
          {
            "name": "month",
            "expr": "date_dim.month",
            "displayName": "Month"
          },
          {
            "name": "month_name",
            "expr": "date_dim.month_name",
            "displayName": "Month Name"
          },
          {
            "name": "business_name",
            "expr": "business.name",
            "displayName": "Business Name"
          },
          {
            "name": "categories",
            "expr": "business.categories",
            "displayName": "Categories"
          },
          {
            "name": "is_open",
            "expr": "business.is_open",
            "displayName": "Is Open"
          },
          {
            "name": "star_rating",
            "expr": "stars",
            "displayName": "Star Rating"
          }
        ],
        "joins": [
          {
            "name": "business",
            "source": "demo_catalog.demo_yelp_academic.ss_zz_gold_dim_business",
            "on": "source.SK_business_id = business.SK_business_id"
          },
          {
            "name": "date_dim",
            "source": "demo_catalog.demo_yelp_academic.ss_zz_gold_dim_date",
            "on": "source.SK_date_id = date_dim.SK_date_id"
          }
        ]
      }
    }
  ],
  "pages": [
